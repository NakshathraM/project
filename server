const express = require("express");
const cors = require("cors");

const connectDB = require("./config/db");

const app = express();

connectDB();

app.use(cors());

app.use(express.json());

app.use(
    "/api/habits",
    require("./routes/habitRoutes")
);

app.listen(5000, () => {
    console.log(
        "Server Running on Port 5000"
    );
});